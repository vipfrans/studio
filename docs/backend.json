
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "بيانات المستخدم الأساسية، الرصيد، الإحصائيات، والرتبة.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "usernameLowercase": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["OWNER", "ADMIN", "VIP", "MEMBER", "USER"] },
        "avatarUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "uid": { "type": "string" },
        "internalEmail": { "type": "string" },
        "hasChangedUsername": { "type": "boolean" },
        "stats": {
          "type": "object",
          "properties": {
            "totalGames": { "type": "number" },
            "totalWagered": { "type": "number" },
            "totalDeposited": { "type": "number" },
            "totalWithdrawal": { "type": "number" }
          }
        },
        "gamesHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "game": { "type": "string" },
              "amount": { "type": "number" },
              "type": { "type": "string", "enum": ["WIN", "LOSS"] },
              "createdAt": { "type": "string", "format": "date-time" }
            }
          }
        }
      },
      "required": ["username", "balance", "role"]
    },
    "InviteKey": {
      "title": "Invite Key",
      "description": "مفتاح دعوة للسماح بالتسجيل مع دعم لعدد الاستخدامات.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "usedBy": { "type": "string" },
        "maxUses": { "type": "number" },
        "currentUses": { "type": "number" }
      },
      "required": ["key"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "رسالة في الدردشة الحقيقية.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "username", "text", "role", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين."
    },
    "/invite_keys/{keyId}": {
      "schema": "InviteKey",
      "description": "مفاتيح الدعوة."
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "رسائل الدردشة الحقيقية."
    }
  }
}
