
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "بيانات المستخدم الأساسية والرصيد.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "email": { "type": "string" },
        "balance": { "type": "number" },
        "role": { "type": "string", "enum": ["ADMIN", "VIP", "MEMBER"] },
        "isVerified": { "type": "boolean" },
        "uid": { "type": "string" }
      },
      "required": ["username", "email", "balance", "role"]
    },
    "VerificationCode": {
      "title": "Verification Code",
      "description": "كود التحقق المؤقت لتفعيل الحساب.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "code", "createdAt"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "إعلان عالمي يظهر لجميع المستخدمين.",
      "type": "object",
      "properties": {
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderName", "text", "active"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "رسالة في الدردشة الحقيقية.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "text": { "type": "string" },
        "role": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "replyTo": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "text": { "type": "string" }
          }
        }
      },
      "required": ["userId", "username", "text", "role", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "ملفات المستخدمين."
    },
    "/verification_codes/{codeId}": {
      "schema": "VerificationCode",
      "description": "أكواد التحقق المؤقتة."
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "الإعلانات العالمية."
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "رسائل الدردشة الحقيقية."
    }
  }
}
